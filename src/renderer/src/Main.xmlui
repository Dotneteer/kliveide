<App
  layout="desktop"
  name="Klive IDE"
  var.currentTheme=""
  var.isEmu="{window.location.search.indexOf('window=emulator') >= 0}"
  defaultTone="{currentTheme}"
>
  <SharedAppState
    id="state"
    onDidChange="arg => currentTheme = arg.theme" />
  <EmuApp when="{isEmu}" />
  <IdeApp when="{!isEmu}" />
</App>
