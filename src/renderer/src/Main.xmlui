<App
  layout="desktop"
  name="Klive IDE"
  scrollWholePage="{false}"
  noScrollbarGutters="{true}"
  var.currentTheme="dark"
  defaultTone="{currentTheme}"
>
  <SharedAppState
    id="state"
    onDidChange="arg => currentTheme = (arg.theme === 'light' || arg.theme === 'dark') ? arg.theme : currentTheme" />
  <EmuApp when="{state.isEmulatorWindow()}" />
  <IdeApp when="{!state.isEmulatorWindow()}" />
</App>
