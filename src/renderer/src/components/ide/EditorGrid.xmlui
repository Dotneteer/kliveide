<Component
  name="EditorGrid"
  var.layout="{state.value.idePanelLayout.documentLayout}"
  var.renderedNode="{layout.maximizedGroupId ? { type: 'group', groupId: layout.maximizedGroupId } : layout.root}"
>
  <SharedAppState id="state" />
  <VStack
    width="100%"
    height="100%"
    gap="0"
    overflowX="hidden"
    overflowY="hidden"
    backgroundColor="$backgroundColor-Editor"
  >
    <EditorLayoutNode
      node="{renderedNode}"
      path=""
    />
  </VStack>
</Component>
