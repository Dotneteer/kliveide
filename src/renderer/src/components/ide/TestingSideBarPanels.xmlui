<Component name="TestingSideBarPanels">
  <SideBarPanelStack minPanelSize="{120}" height="100%">
    <SideBarPanelItem
      panelId="testing.tests"
      title="TESTS"
      expanded="{$props.testsExpanded}"
      initialSize="{1000}"
      onToggle="emitEvent('toggleTests')"
    >
      <PanelRenderer rendererId="testingTests" placement="primarySideBar" chrome="compact" />
    </SideBarPanelItem>
  </SideBarPanelStack>
</Component>
