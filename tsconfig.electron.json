{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "outDir": "dist-electron",
    "rootDir": "src/electron",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node10",
    "skipLibCheck": true,
    "types": ["node", "electron-vite/node"]
  },
  "include": ["src/electron"]
}
