{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "module": "commonjs",
    "target": "ESNext",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": "..",
    "downlevelIteration": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["./**/*", "../src/**/*"],
  "exclude": ["node_modules", "**/build/*", "**/*.d.ts"]
}
