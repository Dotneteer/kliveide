; [123] 
; [124] begin

; var Duration(+6), Pitch(+4), Frequency(@global68), Cycles(@global69), DE(@global70), HL(@global71)

__Beep67:                               ; Prologue
                ld      hl,(display+2)
                push    hl
                ld      (display+2),sp
                ld      hl,-16          ; Space
