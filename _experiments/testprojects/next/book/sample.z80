; [83] 
; [84] (**
; [85]  * Plays a tone. Frequency is in Hz. Duration is in milliseconds. The
; [86]  * Spectrum does not have dedicated sound hardware, so the speaker has to
; [87]  * be turned on and off with precise timing by a ROM routine. As a result,
; [88]  * the procedure is synchronous, i.e. the program has to wait for the whole
; [89]  * duration of the tone. When calling this on a ZX Spectrum Next in the
; [90]  * native personality, set the CPU Speed to 3.5 MHz first. Otherwise both
; [91]  * the frequency and the duration will be wrong.
; [92]  *)
; [93] procedure Sound(Frequency, Duration: Integer);

; [94] var
; [95]   Cycles: Real;
global64:       ds      6,0             ; Global Cycles
; [96] 
; [97]   procedure RomBeep(HL, DE: Integer); register;     external '$03b5';
; [98] 
; [99] begin

; var Frequency(+6), Duration(+4), Cycles(@global64)

__Sound63:                              ; Prologue
                ld      hl,(display+2)
                push    hl
                ld      (display+2),sp
                push    hl
                push    hl
                push    hl
; [100]   Cycles := 3500000.0 / (2 * Frequency);
                ld      hl,global64 + 0
                push    hl
                constfp 0x0096,0x8000,0x559F
                pushfp
                ld      de,2            ; Literal 2
                push    de
                ld      hl,(display+2)  ; Local Frequency
                ld      de,6
                add     hl,de
                push    hl
                pop     hl
                ld      de,(hl)
                push    de
                pop     de
                pop     hl
                call    __mul16         ; Mul
                push    hl
                pop     hl
                call    FLOAT
                pushfp
                popfp
                exx
                popfp
                call    FPDIV
                pushfp
                popfp
                exx
                pop     hl
                call    __storefp
; [101]   RomBeep(Trunc(Cycles / 4 - 30.125), Trunc(Duration * Frequency));
                ld      hl,global64 + 0
                push    hl
                pop     hl
                call    __loadfp
                pushfp
                ld      de,4            ; Literal 4
                push    de
                pop     hl
                call    FLOAT
                pushfp
                popfp
                exx
                popfp
                call    FPDIV
                pushfp
                constfp 0x0085,0x0000,0x7100
                pushfp
                popfp
                exx
                popfp
                call    FPSUB
                pushfp
                popfp
                call    FIX
                push    hl
                ld      hl,(display+2)  ; Local Duration
                ld      de,4
                add     hl,de
                push    hl
                pop     hl
                ld      de,(hl)
                push    de
                ld      hl,(display+2)  ; Local Frequency
                ld      de,6
                add     hl,de
                push    hl
                pop     hl
                ld      de,(hl)
                push    de
                pop     de
                pop     hl
                call    __mul16         ; Mul
                push    hl
                pop     hl
                call    FLOAT
                pushfp
                popfp
                call    FIX
                push    hl
                pop     de
                pop     hl
                call    $03b5
; [102] end;
exit66:         ld      sp,(display+2)  ; Epilogue
                pop     hl
                ld      (display+2),hl
                ret
; [103] 
; [104] (**
; [105]  * Plays a note. Duration is in seconds. Pitch is the key number on a
; [106]  * piano, similar to MIDI, but with 0 being the middle C. See the BEEP
; [107]  * command in the ZX Spectrum BASIC manual for details. The Spectrum does
; [108]  * not have dedicated sound hardware, so the speaker has to be turned on
; [109]  * and off with precise timing by a ROM routine. As a result, the procedure
; [110]  * is synchronous, i.e. the program has to wait for the whole duration of
; [111]  * the note. When calling this on a ZX Spectrum Next in the native
; [112]  * personality, set the CPU Speed to 3.5 MHz first. Otherwise both the
; [113]  * frequency and the duration will be wrong.
; [114]  *)
; [115] procedure Beep(Duration: Real; Pitch: Integer);

; [116] const
; [117]   LN2 = 0.693147180559945;
; [118] var
; [119]   Frequency, Cycles: Real;
global68:       ds      6,0             ; Global Frequency
global69:       ds      6,0             ; Global Cycles
