                ld      d,0
                push    de
                pop     hl
                call    FLOAT
                pushfp
                popfp
                exx
                popfp
                call    FPMUL
                pushfp
                constfp 0x0089,0x0000,0x0000
                pushfp
                ld      de,23673        ; Literal 23673
                push    de
                pop     hl
                ld      e,(hl)
                ld      d,0
                push    de
                pop     hl
