                push    de
                ld      hl,global68 + 0
                push    hl
                pop     hl
                call    __loadfp
                pushfp
                popfp
                exx
                pop     hl
                exx
                pushfp
                exx
                call    FLOAT
                exx
                popfp
                exx
                pushfp
                exx
                pushfp
                popfp
                exx
                popfp
                call    FPMUL
                pushfp
                popfp
                exx
                popfp
                call    FPDIV
                pushfp
                popfp
                exx
                pop     hl
                call    __storefp
; [127]   RomBeep(Trunc(Cycles / 4 - 30.125), Trunc(Duration * Frequency));
                ld      hl,global69 + 0
                push    hl
                pop     hl
                call    __loadfp
                pushfp
                ld      de,4            ; Literal 4
                push    de
                pop     hl
                call    FLOAT
                pushfp
                popfp
                exx
                popfp
                call    FPDIV
                pushfp
                constfp 0x0085,0x0000,0x7100
                pushfp
                popfp
                exx
                popfp
                call    FPSUB
                pushfp
                popfp
                call    FIX
                push    hl
                ld      hl,(display+2)  ; Local Duration
                ld      de,6
                add     hl,de
                push    hl
                pop     hl
                call    __loadfp
                pushfp
                ld      hl,global68 + 0
                push    hl
                pop     hl
                call    __loadfp
                pushfp
                popfp
                exx
                popfp
                call    FPMUL
                pushfp
                popfp
                call    FIX
                push    hl
                pop     de
                pop     hl
                call    $03b5
; [128] end;
exit73:         ld      sp,(display+2)  ; Epilogue
                pop     hl
                ld      (display+2),hl
                ret
; [129] 
; [130] (**
; [131]  * Returns the value of the 24 bit frame counter that is normally increased by
; [132]  * one during the 50 Hz interrupt routine. Multiplying this value by 20 results
; [133]  * in the machine's uptime in milliseconds (minus the time interrupts where
; [134]  * disabled).
; [135]  *)
; [136] function Frames: Real;

; [137] begin
; var Frames(@RESULT)

__Frames74:                             ; Prologue
                ld      hl,(display+2)
                push    hl
                ld      (display+2),sp
; [138]   Frames := 65536.0 * Mem[23674] + 256.0 * Mem[23673] + Mem[23672];
                ld      hl,(display+2)  ; Local Frames
                ld      de,4
                add     hl,de
                push    hl
                constfp 0x0091,0x0000,0x0000
                pushfp
                ld      de,23674        ; Literal 23674
                push    de
                pop     hl
