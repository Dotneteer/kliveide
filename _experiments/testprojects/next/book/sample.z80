; [9] 
; [10] const
; [11]   (**
; [12]    * Defines the default with of the Spectrum screen in characters.
; [13]    *)
; [14]   ScreenWidth  = 32;
; [15] 
; [16]   (**
; [17]    * Defines the default height of the Spectrum screen in characters.
; [18]    *)
; [19]   ScreenHeight = 22;
; [20] 
; [21]   (**
; [22]    * Defines the line break convention used by the Spectrum.
; [23]    *)
; [24]   LineBreak = #13;
; [25] 
; [26] (**
; [27]  * Clears the screen. Uses the most recently defined text color and
; [28]  * background for the attribute area.
; [29]  *)
; [30] procedure ClrScr; register;                         external 'zx_clrscr';
; [31] 
; [32] (**
; [33]  * Moves the the cursor (aka printing position) to a given location. Note
; [34]  * that, unlike ZX BASIC, Pascal expects the screen column (X) first,
; [35]  * followed by the screen row (Y).
; [36]  *)
; [37] procedure GotoXY(X, Y: Integer); register;          external 'zx_gotoxy';

; [38] 
; [39] (**
; [40]  * Sets the text color (0..7).
; [41]  *)
; [42] procedure TextColor(Color: Integer); register;      external 'zx_color';

; [43] 
; [44] (**
; [45]  * Sets the text background (0..7).
; [46]  *)
; [47] procedure TextBackground(Color: Integer); register; external 'zx_background';

; [48] 
; [49] (**
; [50]  * Returns True if a key has been pressed (and can be queried using the
; [51]  * ReadKey function), False if not.
; [52]  *)
; [53] function KeyPressed: Boolean; register;             external 'zx_testkey';

; [54] 
; [55] (**
; [56]  * Reads a key press and returns the corresponding ASCII character. Does
; [57]  * echo the character to the screen. Waits for a key press, if necessary,
; [58]  * so use KeyPressed first if you don't want your program to be delayed.
; [59]  *)
; [60] function ReadKey: Char; register;                   external 'zx_readkey';

; [61] 
; [62] (* --------------------------------------------------------------------- *)
; [63] (* --- Misc. standard functions ---------------------------------------- *)
; [64] (* --------------------------------------------------------------------- *)
; [65] 
; [66] (**
; [67]  * Waits for the given interval in milliseconds. Note that, since the
; [68]  * maskable 50 Hz interrupt is being used as a basis, the actual interval
; [69]  * is a multiple of 20 ms plus/minus "a bit", depending on at which point
; [70]  * in the interrupt cycle the procedure is invoked. If interrupts are
; [71]  * disabled, calling this procedure will hang the machine.
; [72]  *)
; [73] procedure Delay(Duration: Integer); register;       external 'zx_delay';

