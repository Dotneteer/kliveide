                ld      de,9            ; Literal 9
                push    de
                pop     de
                pop     hl
                xor     a
                sbc     hl,de
                push    hl
                pop     hl
                call    FLOAT
                pushfp
                constfp 0x0084,0x0000,0x4000
                pushfp
                popfp
                exx
                popfp
                call    FPDIV
                pushfp
                constfp 0xD180,0x17F7,0x3172
                pushfp
                popfp
                exx
                popfp
                call    FPMUL
                pushfp
                popfp
                call    EXP
                pushfp
                popfp
                exx
                popfp
                call    FPMUL
                pushfp
                popfp
                exx
                pop     hl
                call    __storefp
; [126]   Cycles := 3500000.0 / (2 * Frequency);
                ld      hl,global69 + 0
                push    hl
