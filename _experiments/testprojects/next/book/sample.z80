                pushfp
                popfp
                exx
                popfp
                call    FPADD
                pushfp
                ld      de,23672        ; Literal 23672
                push    de
                pop     hl
                ld      e,(hl)
                ld      d,0
                push    de
                pop     hl
                call    FLOAT
                pushfp
                popfp
                exx
                popfp
                call    FPADD
                pushfp
                popfp
                exx
                pop     hl
                call    __storefp
; [139] end;
